# Generic AI Query
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5-mini

# MemWal local MCP HTTP fallback
MEMWAL_MCP_URL=http://localhost:3005/api/mcp
MEMWAL_AUTHORIZATION=Bearer replace-with-delegate-key
MEMWAL_ACCOUNT_ID=
MEMWAL_MCP_CREDENTIALS_PATH=~/.memwal/credentials.json
CONTEXTMEM_PUBLIC_API_URL=http://localhost:8791
CONTEXTMEM_HOSTED_API_URL=http://localhost:8787
CONTEXTMEM_HOSTED_IMPORT_TOKEN=replace-with-cloudflare-namespace-import-token

# Walrus persistent storage + chain reads via Tatum (mainnet API key required
# for /v4/data/storage/upload). Also powers the @tatumio/blockchain-mcp server.
TATUM_API_KEY=
TATUM_STORAGE_URL=https://api.tatum.io/v4/data/storage/upload
SUI_FULLNODE_URL=https://fullnode.mainnet.sui.io

# Account/session encryption for local API and Cloudflare Workers secrets
CONTEXTMEM_ACCOUNT_SECRET=replace-with-32-byte-secret
CONTEXTMEM_NAMESPACE_IMPORT_TOKEN=replace-with-cloudflare-namespace-import-token
CONTEXTMEM_WORKER_BASE_URL=http://localhost:8787

# API server
CONTEXTMEM_RUNS_DIR=./runs
CONTEXTMEM_API_PORT=8791

# Web app feature flags
VITE_CONTEXTMEM_DEV_AUTH=false
