# ============================================================================
# ContextMeM — single environment reference.
#
#   cp .env.example .env.local      # then fill in the blanks
#
# .env.local is gitignored. Bun auto-loads it from the repo root for the API,
# CLI, and MCP. For local dev, `bun run dev` runs the web + API together; you
# really only NEED the MemWal + OpenAI keys to get going.
# ============================================================================

# ── Frontend · apps/web (Vite) ──────────────────────────────────────────────
# Where the web app sends API calls. In local dev the Vite proxy forwards
# /api → VITE_CONTEXTMEM_PROXY_TARGET, so this can stay on localhost.
VITE_CONTEXTMEM_API_BASE=http://localhost:8791
VITE_CONTEXTMEM_PROXY_TARGET=http://localhost:8791
VITE_CONTEXTMEM_DEV_AUTH=false

# ── Local API server · apps/api (Fastify) ───────────────────────────────────
CONTEXTMEM_API_PORT=8791
CONTEXTMEM_RUNS_DIR=./runs
# 32+ byte secret for account/session encryption (Generate in /app/settings).
CONTEXTMEM_ACCOUNT_SECRET=replace-with-32-byte-secret
# Optional Ed25519 key used to sign run snapshots.
CONTEXTMEM_SIGNING_KEY=

# ── Walrus Memory · MemWal (required for remember / recall) ─────────────────
MEMWAL_ACCOUNT_ID=
MEMWAL_PRIVATE_KEY=                                  # raw Ed25519 hex seed
MEMWAL_API_URL=https://relayer.memwal.ai            # staging: https://relayer.staging.memwal.ai
MEMWAL_TRANSPORT=mcp                                 # mcp | sdk | auto

# ── AI Query · OpenAI-compatible ────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5-mini

# ── Walrus storage + chain reads · Tatum (CLI/MCP `contextmem storage push`) ─
TATUM_API_KEY=                                       # Tatum mainnet key
TATUM_STORAGE_URL=https://api.tatum.io/v4/data/storage/upload
SUI_FULLNODE_URL=https://fullnode.mainnet.sui.io
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-mainnet.walrus.space

# ── Web scraping fallback ───────────────────────────────────────────────────
FIRECRAWL_API_KEY=

# ── Hosted backend worker · Cloudflare (apps/api/cloudflare) ────────────────
# Public URL of the deployed worker (your account's workers.dev subdomain).
CONTEXTMEM_WORKER_BASE_URL=https://contextmem-hosted-namespace-mcp.petlofi.workers.dev
CONTEXTMEM_DEMO_SAMPLE_TARGET=https://seal-docs.wal.app/
CONTEXTMEM_NAMESPACE_IMPORT_TOKEN=replace-with-namespace-import-token
CONTEXTMEM_WEBHOOK_SECRET=
# Hosted namespace import flow (web app → worker).
CONTEXTMEM_HOSTED_API_URL=http://localhost:8787
CONTEXTMEM_HOSTED_IMPORT_TOKEN=replace-with-namespace-import-token
CONTEXTMEM_PUBLIC_API_URL=http://localhost:8791

# ── Cloudflare deploy · CI / wrangler ───────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=52cb969c099635516787d017aab0559b
CLOUDFLARE_API_TOKEN=                                # Workers + Pages edit, D1, R2, Queues, Workers AI

# ── React Bits Pro (only if using its components) ───────────────────────────
REACTBITS_LICENSE_KEY=
