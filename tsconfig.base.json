{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": false,
    "paths": {
      "@contextmem/core": ["./packages/core/src/index.ts"],
      "@contextmem/walrus": ["./packages/walrus/src/index.ts"],
      "@contextmem/memwal": ["./packages/memwal/src/index.ts"],
      "@contextmem/mcp": ["./packages/mcp/src/index.ts"],
      "@contextmem/mcp/hosted": ["./packages/mcp/src/hosted.ts"]
    }
  }
}
